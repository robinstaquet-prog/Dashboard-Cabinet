# ─────────────────────────────────────────────────────────────────
#  Configuration du Dashboard Cabinet — copier en "config.env"
#  et remplir les valeurs ci-dessous.
#  Ce fichier NE DOIT PAS être partagé (contient des données sensibles).
# ─────────────────────────────────────────────────────────────────

# Mot de passe de chiffrement AES-256 des dossiers patients (obligatoire)
# Choisir un mot de passe long et le noter dans un gestionnaire de mots de passe.
PIPELINE_PASSWORD=remplacer_par_votre_mot_de_passe

# Clé API Anthropic (obligatoire pour le traitement des photos)
# Obtenir sur : console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-remplacer_par_votre_cle

# Durée de conservation des photos sources après traitement (en jours)
# 0 = suppression immédiate (option la plus stricte pour nLPD)
PIPELINE_ARCHIVE_RETENTION_DAYS=30

# Dossier Téléchargements (facultatif — détecté automatiquement)
# Décommenter et adapter uniquement si Tailscale enregistre ailleurs :
# PIPELINE_DOWNLOADS_FOLDER=C:\Users\VotreNom\Downloads

# Dossier de stockage des données (facultatif — par défaut : pipeline\data\)
# PIPELINE_DATA_DIR=C:\Users\VotreNom\Desktop\DASHBOARD CABINET\pipeline\data
